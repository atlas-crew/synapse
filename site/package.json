{
  "name": "horizon-docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copy:brand": "mkdir -p public/brand && cp ../brand/horizon-brand-guidelines/*.html ../brand/horizon-brand-guidelines/*.png ../brand/horizon-brand-guidelines/*.zip public/brand/",
    "dev": "npm run copy:brand && vitepress dev",
    "build": "npm run copy:brand && vitepress build",
    "preview": "vitepress preview"
  },
  "devDependencies": {
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17",
    "mermaid": "^11.4.1"
  }
}
