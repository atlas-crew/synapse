{
  "name": "atlascrew-monorepo",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "build": "pnpm exec nx run-many --target=build --all",
    "test": "pnpm exec nx run-many --target=test --all",
    "lint": "pnpm exec nx run-many --target=lint --all",
    "type-check": "pnpm exec nx run-many --target=type-check --all",
    "graph": "pnpm exec nx graph",
    "signal-horizon:api": "pnpm --filter @atlascrew/signal-horizon-api dev",
    "signal-horizon:ui": "pnpm --filter @atlascrew/signal-horizon-ui dev",
    "signal-horizon:standalone": "pnpm exec nx run signal-horizon-api:build:standalone",
    "signal-horizon:release": "node apps/signal-horizon/scripts/package-standalone-release.mjs",
    "signal-horizon:release:tag": "node apps/signal-horizon/scripts/create-release-tag.mjs",
    "signal-horizon:publish:dry-run": "node apps/signal-horizon/scripts/publish-standalone-package.mjs --dry-run",
    "signal-horizon:publish": "node apps/signal-horizon/scripts/publish-standalone-package.mjs",
    "synapse-client:build": "pnpm --filter @atlascrew/synapse-client build",
    "synapse-api:build": "pnpm --filter @atlascrew/synapse-api build",
    "synapse-waf:test": "pnpm --filter synapse-waf test"
  },
  "devDependencies": {
    "nx": "21.6.4"
  }
}
