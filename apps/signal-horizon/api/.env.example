# Signal Horizon Hub - Environment Configuration

# Server
NODE_ENV=development
PORT=3100
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signal_horizon?schema=public

# WebSocket Configuration
WS_SENSOR_PATH=/ws/sensors
WS_DASHBOARD_PATH=/ws/dashboard
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_SENSOR_CONNECTIONS=1000
WS_MAX_DASHBOARD_CONNECTIONS=100

# Aggregator (Signal Batching)
SIGNAL_BATCH_SIZE=100
SIGNAL_BATCH_TIMEOUT_MS=5000

# Broadcaster (Blocklist Push)
BLOCKLIST_PUSH_DELAY_MS=50
BLOCKLIST_CACHE_SIZE=100000

# Security
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=http://localhost:5173,http://localhost:4200,http://localhost:5180,http://127.0.0.1:5180
# Encrypt sensitive Pingora config fields at rest (required in production)
CONFIG_ENCRYPTION_KEY=replace-with-strong-key
# Telemetry JWT (required for /_sensor/report)
TELEMETRY_JWT_SECRET=replace-with-strong-jwt-secret

# Logging
LOG_LEVEL=info

# ClickHouse (Historical Data Storage)
# Set CLICKHOUSE_ENABLED=true for production mode with historical queries
CLICKHOUSE_ENABLED=false
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=signal_horizon
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_COMPRESSION=true
CLICKHOUSE_MAX_CONNECTIONS=10
