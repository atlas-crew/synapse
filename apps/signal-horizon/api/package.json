{
  "name": "@atlascrew/signal-horizon-api",
  "version": "0.1.0",
  "description": "Signal Horizon Hub API - Fleet intelligence for collective defense",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsup src/index.ts --format esm --dts && cp -r ../docs ./dist/docs",
    "build:standalone": "pnpm --dir ../../.. exec nx run signal-horizon-api:build:standalone",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "rules:sync": "tsx prisma/sync-synapse-rules.ts",
    "scenario:cred-stuff": "tsx prisma/seed/scenarios/credential-stuffing.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@atlascrew/apparatus-lib": "^0.9.2",
    "@clickhouse/client": "^1.15.0",
    "@prisma/client": "^6.9.0",
    "@signal-horizon/shared": "workspace:*",
    "bullmq": "^5.34.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "ws": "^8.18.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^22.13.17",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.24.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.9.0",
    "supertest": "^7.1.4",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.48.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
