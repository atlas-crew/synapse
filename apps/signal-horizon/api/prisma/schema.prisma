// Signal Horizon Hub - Multi-tenant database schema
// Fleet intelligence for collective defense across Synapse sensors

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Multi-Tenant Core
// =============================================================================

model Tenant {
  id                String            @id @default(cuid())
  name              String
  tier              TenantTier        @default(STANDARD)
  sharingPreference SharingPreference @default(CONTRIBUTE_AND_RECEIVE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  apiKeys           ApiKey[]
  sensors           Sensor[]
  signals           Signal[]
  threats           Threat[]
  blocklistEntries  BlocklistEntry[]
  campaigns         Campaign[]
  warRooms          WarRoom[]
  warRoomActivities WarRoomActivity[]

  // Beam relations
  beamEndpoints      Endpoint[]      @relation("TenantEndpoints")
  beamRules          CustomerRule[]  @relation("TenantRules")
  beamBlockDecisions BlockDecision[] @relation("TenantBlockDecisions")

  @@map("tenants")
}

enum TenantTier {
  FREE // Basic protection, receive-only
  STANDARD // Full bidirectional sharing
  ENTERPRISE // Priority push, advanced analytics
  PLATINUM // Custom retention, dedicated support
}

enum SharingPreference {
  CONTRIBUTE_AND_RECEIVE // Full participation
  RECEIVE_ONLY // Consume fleet intel, don't share
  CONTRIBUTE_ONLY // Share but don't receive (rare)
  ISOLATED // No fleet participation
}

// =============================================================================
// Authentication
// =============================================================================

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  keyHash    String    @unique // SHA-256 of the actual key
  name       String
  scopes     String[] // e.g., ["signal:write", "blocklist:read"]
  rateLimit  Int       @default(1000) // requests per minute
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  isRevoked  Boolean   @default(false)

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([keyHash])
  @@map("api_keys")
}

// =============================================================================
// Sensors
// =============================================================================

model Sensor {
  id              String          @id @default(cuid())
  tenantId        String
  name            String
  hostname        String? // Machine hostname
  region          String          @default("us-east-1") // Physical or cloud region
  version         String
  connectionState ConnectionState @default(DISCONNECTED)
  lastHeartbeat   DateTime?
  lastSignalAt    DateTime?
  signalsReported Int             @default(0)
  blocksApplied   Int             @default(0)
  ipAddress       String?
  metadata        Json? // Additional sensor info
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Signal Array - System Info
  publicIp     String?
  privateIp    String?
  os           String? // "Ubuntu 22.04 LTS"
  kernel       String? // "5.15.0-89-generic"
  architecture String? // "x86_64"
  instanceType String? // "c5.xlarge"
  lastBoot     DateTime?
  uptime       Int? // Seconds since boot

  // Signal Array - Tunnel/Remote Access
  tunnelActive    Boolean @default(false)
  tunnelSessionId String?

  // Signal Array - Onboarding
  registrationMethod RegistrationMethod @default(MANUAL)
  registrationToken  String?
  approvalStatus     ApprovalStatus     @default(APPROVED)
  approvedAt         DateTime?
  approvedBy         String?

  // Relations
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  signals       Signal[]
  syncState     SensorSyncState?
  commands      FleetCommand[]
  ruleSyncState RuleSyncState[]

  // Signal Array - Relations
  apiKeys           SensorApiKey[]
  diagnosticBundles DiagnosticBundle[]
  updateHistory     SensorUpdate[]

  // Beam relations
  beamEndpoints       Endpoint[]       @relation("SensorEndpoints")
  beamRuleDeployments RuleDeployment[] @relation("SensorRuleDeployments")
  beamBlockDecisions  BlockDecision[]  @relation("SensorBlockDecisions")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([connectionState])
  @@map("sensors")
}

enum ConnectionState {
  CONNECTED
  DISCONNECTED
  RECONNECTING
}

enum RegistrationMethod {
  MANUAL
  AGENT_SCRIPT
  AUTO_DISCOVERY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KeyStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

// =============================================================================
// Threat Signals
// =============================================================================

model Signal {
  id              String     @id @default(cuid())
  tenantId        String
  sensorId        String
  signalType      SignalType
  sourceIp        String?
  fingerprint     String? // Original fingerprint (tenant-specific)
  anonFingerprint String? // SHA-256 for cross-tenant sharing
  severity        Severity
  confidence      Float // 0.0 - 1.0
  eventCount      Int        @default(1)
  metadata        Json? // Signal-specific data
  createdAt       DateTime   @default(now())

  // Relations
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sensor      Sensor         @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  threatLinks ThreatSignal[]

  @@index([tenantId])
  @@index([sensorId])
  @@index([signalType])
  @@index([anonFingerprint])
  @@index([createdAt])
  @@index([severity]) // Filter by severity level
  // Compound indexes for efficient query patterns
  @@index([createdAt, sensorId]) // Range queries by sensor
  @@index([signalType, createdAt]) // Correlation queries by type
  @@index([tenantId, createdAt]) // Tenant-scoped time ranges
  @@index([anonFingerprint, createdAt]) // Cross-tenant fingerprint analysis
  @@index([severity, createdAt]) // Dashboard: severity over time
  @@index([tenantId, severity, createdAt]) // Tenant dashboard severity filter
  @@map("signals")
}

enum SignalType {
  IP_THREAT // Malicious IP activity
  FINGERPRINT_THREAT // Browser/TLS fingerprint threat
  CAMPAIGN_INDICATOR // Campaign correlation signal
  CREDENTIAL_STUFFING // Credential stuffing attempt
  RATE_ANOMALY // Unusual request patterns
  BOT_SIGNATURE // Automated bot detection
  IMPOSSIBLE_TRAVEL // Login from geographically impossible locations
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// =============================================================================
// Aggregated Threats
// =============================================================================

model Threat {
  id              String     @id @default(cuid())
  tenantId        String? // Null for fleet-wide threats
  threatType      ThreatType
  indicator       String // IP, fingerprint hash, etc.
  anonIndicator   String? // Anonymized for cross-tenant
  riskScore       Float // 0.0 - 100.0
  fleetRiskScore  Float? // Aggregated across fleet
  firstSeenAt     DateTime
  lastSeenAt      DateTime
  hitCount        Int        @default(1)
  tenantsAffected Int        @default(1)
  isFleetThreat   Boolean    @default(false) // 2+ tenants = fleet threat
  ttl             DateTime? // When to expire
  metadata        Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  tenant           Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  signalLinks      ThreatSignal[]
  blocklistEntries BlocklistEntry[]
  campaignLinks    CampaignThreat[]

  @@unique([threatType, indicator])
  @@index([tenantId])
  @@index([threatType])
  @@index([isFleetThreat])
  @@index([riskScore])
  @@index([lastSeenAt])
  // Compound indexes for threat queries
  @@index([isFleetThreat, lastSeenAt]) // Fleet threats by recency
  @@index([threatType, lastSeenAt]) // Threat type analysis
  @@index([riskScore, lastSeenAt]) // High-risk threats dashboard
  @@map("threats")
}

enum ThreatType {
  IP
  FINGERPRINT
  ASN
  USER_AGENT
  TLS_FINGERPRINT
  CREDENTIAL_PATTERN
}

// Junction table for Signal-Threat relationship
model ThreatSignal {
  id        String   @id @default(cuid())
  threatId  String
  signalId  String
  createdAt DateTime @default(now())

  threat Threat @relation(fields: [threatId], references: [id], onDelete: Cascade)
  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@unique([threatId, signalId])
  @@map("threat_signals")
}

// =============================================================================
// Blocklist
// =============================================================================

model BlocklistEntry {
  id                String            @id @default(cuid())
  tenantId          String? // Null for fleet-wide blocks
  threatId          String?
  blockType         BlockType
  indicator         String
  source            BlockSource
  reason            String?
  expiresAt         DateTime?
  propagatedAt      DateTime? // When pushed to sensors
  propagationStatus PropagationStatus @default(PENDING)
  sensorsNotified   Int               @default(0)
  createdAt         DateTime          @default(now())

  // Relations
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  threat Threat? @relation(fields: [threatId], references: [id], onDelete: SetNull)

  @@unique([blockType, indicator, tenantId])
  @@index([tenantId])
  @@index([blockType])
  @@index([propagationStatus])
  @@index([expiresAt])
  @@map("blocklist_entries")
}

enum BlockType {
  IP
  IP_RANGE
  FINGERPRINT
  ASN
  USER_AGENT
}

enum BlockSource {
  AUTOMATIC // System-detected threat
  MANUAL // SOC operator action
  FLEET_INTEL // Cross-tenant correlation
  EXTERNAL_FEED // Third-party threat feed
  WAR_ROOM // War room quick action
}

enum PropagationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  PARTIAL // Some sensors failed
}

// =============================================================================
// Campaigns
// =============================================================================

model Campaign {
  id                 String         @id @default(cuid())
  tenantId           String? // Null for cross-tenant campaigns
  name               String
  description        String?
  status             CampaignStatus @default(ACTIVE)
  severity           Severity
  isCrossTenant      Boolean        @default(false)
  tenantsAffected    Int            @default(1)
  confidence         Float // 0.0 - 1.0
  correlationSignals Json? // Array of correlation evidence
  firstSeenAt        DateTime
  lastActivityAt     DateTime
  resolvedAt         DateTime?
  resolvedBy         String?
  metadata           Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // Relations
  tenant       Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  threatLinks  CampaignThreat[]
  warRoomLinks WarRoomCampaign[]

  @@index([tenantId])
  @@index([status])
  @@index([isCrossTenant])
  @@index([lastActivityAt])
  // Compound indexes for dashboard queries
  @@index([status, lastActivityAt]) // Active campaigns by recency
  @@index([isCrossTenant, status]) // Fleet campaigns filter
  @@index([tenantId, status, lastActivityAt]) // Tenant dashboard
  @@map("campaigns")
}

enum CampaignStatus {
  ACTIVE
  MONITORING
  RESOLVED
  FALSE_POSITIVE
}

// Junction table for Campaign-Threat relationship
model CampaignThreat {
  id         String   @id @default(cuid())
  campaignId String
  threatId   String
  role       String? // e.g., "primary_actor", "infrastructure"
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  threat   Threat   @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@unique([campaignId, threatId])
  @@map("campaign_threats")
}

// =============================================================================
// War Room
// =============================================================================

model WarRoom {
  id          String        @id @default(cuid())
  tenantId    String
  name        String
  description String?
  status      WarRoomStatus @default(ACTIVE)
  priority    Priority      @default(MEDIUM)
  leaderId    String? // User ID of incident lead
  createdAt   DateTime      @default(now())
  closedAt    DateTime?
  updatedAt   DateTime      @updatedAt

  // Relations
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  activities    WarRoomActivity[]
  campaignLinks WarRoomCampaign[]

  @@index([tenantId])
  @@index([status])
  @@map("war_rooms")
}

enum WarRoomStatus {
  ACTIVE
  PAUSED
  CLOSED
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model WarRoomActivity {
  id          String             @id @default(cuid())
  warRoomId   String
  tenantId    String
  actorType   ActivityActorType
  actorId     String? // User ID or "horizon-bot"
  actorName   String
  actionType  ActivityActionType
  description String
  metadata    Json? // Action-specific data
  createdAt   DateTime           @default(now())

  // Relations
  warRoom WarRoom @relation(fields: [warRoomId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([warRoomId])
  @@index([tenantId])
  @@index([createdAt])
  @@map("war_room_activities")
}

enum ActivityActorType {
  USER
  HORIZON_BOT
  SYSTEM
}

enum ActivityActionType {
  MESSAGE
  BLOCK_CREATED
  BLOCK_REMOVED
  CAMPAIGN_LINKED
  STATUS_CHANGED
  PRIORITY_CHANGED
  MEMBER_JOINED
  MEMBER_LEFT
  ALERT_TRIGGERED
}

// Junction table for WarRoom-Campaign relationship
model WarRoomCampaign {
  id         String   @id @default(cuid())
  warRoomId  String
  campaignId String
  linkedAt   DateTime @default(now())
  linkedBy   String? // User ID

  warRoom  WarRoom  @relation(fields: [warRoomId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([warRoomId, campaignId])
  @@map("war_room_campaigns")
}

// =============================================================================
// Audit & Analytics
// =============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// Fleet Management
// =============================================================================

model ConfigTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  environment String   @default("production") // production, staging, dev
  config      Json
  hash        String // SHA-256 of config
  version     String   @default("1.0.0")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([environment])
  @@index([isActive])
  @@index([environment, isActive]) // Filter active templates by environment (10x speedup)
  @@map("config_templates")
}

model SensorSyncState {
  id       String @id @default(cuid())
  sensorId String @unique
  sensor   Sensor @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  expectedConfigHash    String
  expectedRulesHash     String
  expectedBlocklistHash String

  actualConfigHash    String?
  actualRulesHash     String?
  actualBlocklistHash String?

  lastSyncAttempt DateTime?
  lastSyncSuccess DateTime?
  syncErrors      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sensorId])
  @@map("sensor_sync_state")
}

model FleetCommand {
  id       String @id @default(cuid())
  sensorId String
  sensor   Sensor @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  commandType String // push_config, push_rules, update, restart, etc.
  payload     Json

  status String  @default("pending") // pending, sent, success, failed, timeout
  result Json?
  error  String?

  queuedAt    DateTime  @default(now())
  sentAt      DateTime?
  completedAt DateTime?
  attempts    Int       @default(0)
  timeoutAt   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sensorId])
  @@index([status])
  @@index([queuedAt])
  @@index([sensorId, status]) // Get pending commands per sensor (10-50x speedup)
  @@index([status, queuedAt]) // FIFO command processing query
  @@map("fleet_commands")
}

model RuleSyncState {
  id       String @id @default(cuid())
  sensorId String
  sensor   Sensor @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  ruleId   String

  status   String    @default("pending") // pending, synced, failed
  syncedAt DateTime?
  error    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sensorId, ruleId])
  @@index([sensorId])
  @@index([ruleId])
  @@index([status])
  @@map("rule_sync_state")
}

// =============================================================================
// Signal Array - Fleet Operations
// =============================================================================

model SensorApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String
  keyPrefix   String // "sk_****8f2k"
  sensorId    String
  sensor      Sensor    @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  status      KeyStatus @default(ACTIVE)
  permissions String[]
  createdBy   String?

  @@index([sensorId])
  @@index([keyHash])
  @@map("sensor_api_keys")
}

model DiagnosticBundle {
  id          String    @id @default(cuid())
  sensorId    String
  sensor      Sensor    @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  requestedAt DateTime  @default(now())
  completedAt DateTime?
  status      String    @default("pending")
  includes    String[]
  downloadUrl String?
  expiresAt   DateTime?
  notes       String?

  @@index([sensorId])
  @@map("diagnostic_bundles")
}

model SensorUpdate {
  id                String    @id @default(cuid())
  sensorId          String
  sensor            Sensor    @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  fromVersion       String
  toVersion         String
  status            String    @default("scheduled")
  scheduledFor      DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  rollbackAvailable Boolean   @default(true)
  logs              String?

  @@index([sensorId])
  @@map("sensor_updates")
}

model FleetAlert {
  id             String    @id @default(cuid())
  tenantId       String
  sensorId       String?
  alertType      String // sensor_offline, high_cpu, high_memory, disk_warning, update_available
  severity       String // info, warning, critical
  title          String
  message        String
  metadata       Json?
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?
  acknowledgedBy String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  @@index([tenantId])
  @@index([sensorId])
  @@index([alertType])
  @@index([acknowledged])
  @@map("fleet_alerts")
}

model RegistrationToken {
  id        String    @id @default(cuid())
  tenantId  String
  token     String    @unique
  name      String?
  region    String?
  expiresAt DateTime
  usedAt    DateTime?
  usedBy    String? // Sensor ID that used this token
  createdAt DateTime  @default(now())
  createdBy String?

  @@index([tenantId])
  @@index([token])
  @@map("registration_tokens")
}

// ============================================
// APEX MODELS - Customer Protection Console
// ============================================

model Endpoint {
  id       String @id @default(cuid())
  tenantId String
  sensorId String

  method       String
  path         String
  pathTemplate String
  service      String @default("default")

  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @updatedAt
  requestCount Int      @default(1)

  hasSchema      Boolean @default(false)
  schemaVersion  String?
  schemaHash     String?
  requestSchema  Json?
  responseSchema Json?

  avgLatencyMs Float?
  p95LatencyMs Float?
  p99LatencyMs Float?
  errorRate    Float?

  riskLevel     String  @default("low")
  authRequired  Boolean @default(false)
  sensitiveData Boolean @default(false)

  metadata Json?

  tenant        Tenant                 @relation("TenantEndpoints", fields: [tenantId], references: [id], onDelete: Cascade)
  sensor        Sensor                 @relation("SensorEndpoints", fields: [sensorId], references: [id], onDelete: Cascade)
  schemaChanges EndpointSchemaChange[]
  ruleBindings  RuleEndpointBinding[]

  @@unique([tenantId, sensorId, method, pathTemplate])
  @@index([tenantId])
  @@index([lastSeenAt])
  @@index([service])
  @@map("beam_endpoints")
}

model EndpointSchemaChange {
  id         String @id @default(cuid())
  endpointId String
  tenantId   String

  changeType String
  field      String
  oldValue   String?
  newValue   String?
  riskLevel  String  @default("low")

  previousHash String?
  currentHash  String?

  detectedAt DateTime @default(now())

  endpoint Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([tenantId, detectedAt])
  @@index([endpointId])
  @@map("beam_schema_changes")
}

model CustomerRule {
  id       String @id @default(cuid())
  tenantId String

  name        String
  description String?
  category    String  @default("custom")
  severity    String  @default("medium")
  action      String  @default("block")

  patterns    Json
  exclusions  Json?
  sensitivity Int   @default(50)

  enabled Boolean @default(true)

  status          String @default("draft")
  rolloutStrategy String @default("immediate")
  rolloutConfig   Json?

  totalSensors    Int @default(0)
  deployedSensors Int @default(0)
  failedSensors   Int @default(0)

  triggers24h   Int       @default(0)
  lastTriggered DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deployedAt DateTime?
  createdBy  String?

  tenant           Tenant                @relation("TenantRules", fields: [tenantId], references: [id], onDelete: Cascade)
  deployments      RuleDeployment[]
  endpointBindings RuleEndpointBinding[]

  @@index([tenantId, status])
  @@index([tenantId, enabled])
  @@map("beam_rules")
}

model RuleDeployment {
  id       String @id @default(cuid())
  ruleId   String
  sensorId String
  tenantId String

  status   String  @default("pending")
  error    String?
  attempts Int     @default(0)

  queuedAt    DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  rule   CustomerRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  sensor Sensor       @relation("SensorRuleDeployments", fields: [sensorId], references: [id], onDelete: Cascade)

  @@unique([ruleId, sensorId])
  @@index([ruleId, status])
  @@index([sensorId])
  @@map("beam_rule_deployments")
}

model RuleEndpointBinding {
  id         String @id @default(cuid())
  ruleId     String
  endpointId String
  tenantId   String

  bindingType String @default("include")

  createdAt DateTime @default(now())

  rule     CustomerRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  endpoint Endpoint     @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@unique([ruleId, endpointId])
  @@map("beam_rule_endpoint_bindings")
}

model BlockDecision {
  id       String @id @default(cuid())
  tenantId String
  sensorId String

  blockId  String @unique
  entityId String
  sourceIp String

  mode      String
  ruleId    String?
  ruleName  String?
  reason    String
  riskScore Int

  requestMethod  String
  requestPath    String
  requestHeaders Json?

  entityState  Json
  matchedRules Json

  decidedAt DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation("TenantBlockDecisions", fields: [tenantId], references: [id], onDelete: Cascade)
  sensor Sensor @relation("SensorBlockDecisions", fields: [sensorId], references: [id], onDelete: Cascade)

  @@index([tenantId, decidedAt])
  @@index([entityId])
  @@index([sourceIp])
  @@map("beam_block_decisions")
}
