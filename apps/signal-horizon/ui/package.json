{
  "name": "@atlascrew/signal-horizon-ui",
  "version": "0.1.0",
  "description": "Signal Horizon Dashboard - Fleet intelligence visualization",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:demo": "VITE_DEMO_MODE=true vite build",
    "deploy": "pnpm build:demo && wrangler deploy",
    "deploy:preview": "pnpm build:demo && wrangler deploy --env preview"
  },
