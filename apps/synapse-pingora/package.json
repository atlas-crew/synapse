{
  "name": "synapse-pingora",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bench:payloads": "node ../load-testing/scripts/bench-generate-payloads.mjs",
    "bench:heavy": "node ../load-testing/scripts/bench-generate-heavy.mjs",
    "bench:scenarios": "node ../load-testing/scripts/bench-generate-scenarios.mjs",
    "bench:setup": "npm run bench:payloads && npm run bench:heavy && npm run bench:scenarios",
    "bench": "cargo bench",
    "test": "cargo test",
    "test-heavy": "cargo test --features heavy-tests -- --ignored --test-threads=1"
  }
}
