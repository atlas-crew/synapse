{
  "title": "Synapse Tunnel Health",
  "uid": "synapse-tunnel",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "Tunnel Connected",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [
        { "expr": "synapse_tunnel_connected" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Reconnect Delay P95 (ms)",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(synapse_tunnel_reconnect_delay_ms_bucket[5m])))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Buffer Overflow (per channel)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(synapse_tunnel_channel_buffer_overflow_total[5m])",
          "legendFormat": "{{channel}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Handler Latency P95 (ms)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, channel) (rate(synapse_tunnel_handler_latency_ms_bucket[5m])))",
          "legendFormat": "{{channel}}"
        }
      ]
    }
  ]
}
