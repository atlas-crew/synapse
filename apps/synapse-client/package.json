{
  "name": "synapse-client",
  "version": "0.1.0",
  "description": "TypeScript client and CLI for Synapse (risk-server) API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "synapse": "dist/cli.js",
    "syn": "dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p .",
    "lint": "echo 'No linter configured'",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@edge-lab/synapse-api": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.22",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
