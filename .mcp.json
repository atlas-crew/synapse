{
  "mcpServers": {
    "backlog": {
      "command": "/opt/homebrew/bin/backlog",
      "args": ["mcp", "start"]
    },
    "codanna": {
      "command": "codanna",
      "args": ["--config", ".codanna/settings.toml", "serve", "--watch"]
    },
    "dash-api": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Kapeli/dash-mcp-server.git",
        "dash-mcp-server"
      ]
    }
  }
}
